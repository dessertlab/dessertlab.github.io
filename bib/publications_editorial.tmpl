<?php
        $_GET['library']=1;
        define('BIBTEXBROWSER_BIBTEX_LINKS',false); // no [bibtex] link by default
        require_once('bibtexbrowser.php');
        global $db;
        $db = new BibDataBase();
        $db->load('bib/pubs_editorial.bib');

        // printing all 2014 entries
        // $query = array('year'=>'2014');
        $query = array('year'=>'.*');
        $entries=$db->multisearch($query);
//        uasort($entries, 'compare_bib_entries');

	$year = 0;
        foreach ($entries as $bibentry) {

                // Get DATE PUBLISHED
                if ($bibentry->hasField(YEAR)) {
                        echo '<div class="item mix vpaper" data-year='.$bibentry->getYear().'>';

			if ($bibentry->getYear() != $year) {
                                $year = $bibentry->getYear();
                                echo '<h2> '.$year.' </h2>';
                        }
                }


                // Get DOI, BIBTEX
                echo '<div class="pubmain">';
                echo '<div class="pubassets">';
                        if (true) {
                                echo '<a href="'.$bibentry->getURL().'" data-toggle="tooltip" data-placement="top" title="BibTeX entry"><i class="fa fa-external-link"></i></a>';
                        }
                        if ($bibentry->hasField('doi')) {
                                echo '<a  href="https://doi.org/'.$bibentry->getField('doi').'" data-toggle="tooltip" data-placement="top" title="Published version"><i class="fa fa-cloud-download"></i></a>';
                        }
                echo '</div>';


                // Get TITLE
                echo '<h4 class="pubtitle"> <strong>';
                echo $bibentry->getTitle();
                echo '</strong></h4>';


                // Get AUTHOR
                if ($bibentry->hasField('author')) {
                        echo '<div class="pubauthor">';
                        $authors = $bibentry->getFormattedAuthorsArray();
                        $num_auth = count($authors);

                        $iter = 1;
                        foreach ($authors as $author) {

                                $parts = explode(",", $author);

                                $substring1 = trim($parts[0]);
                                $substring2 = trim($parts[1]);

                                echo $substring1 . " " . $substring2;

                                if ($iter < $num_auth) {
                                        echo ", ";
                                }

                                $iter++;
                        }
                        echo '</div>';
                }


                // Get BOOK TITLE
                echo '<div>';
                echo $bibentry->getField(BOOKTITLE);
                echo '</div>';



                echo'
                <div class="pubcite"><span class="btn btn-primary">Editorials</span></div>
                </div>
                </div>
                ';

        }
?>
